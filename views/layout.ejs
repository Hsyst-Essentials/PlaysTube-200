<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Video Platform' %></title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
</head>
<body>
  <nav class="glass-nav">
    <div class="navbar">
      <a href="/" class="navbar-brand">
        <div class="navbar-logo">
          <i class="fas fa-play text-white text-xs"></i>
        </div>
        <span class="gradient-text">PlaysTube</span>
      </a>
      <div class="search-bar">
        <input type="text" id="search-input" placeholder="Buscar vídeos..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <button id="btn-search"><i class="fas fa-search"></i></button>
      </div>
      <div class="flex items-center gap-4">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/creator" class="btn-icon"><i class="fas fa-video"></i></a>
          <button id="btn-logout" class="glass-button">Sair</button>
          <div class="channel-avatar" id="user-avatar-nav" style="width:36px;height:36px;cursor:pointer;"><%= user.name.charAt(0).toUpperCase() %></div>
          <div class="context-menu hidden" id="dropdown-menu" style="position:fixed;top:60px;right:1rem;">
            <div class="menu-item"><a href="/user/<%= user.id %>" style="color:inherit;text-decoration:none;">Perfil</a></div>
            <div class="menu-item"><a href="/creator" style="color:inherit;text-decoration:none;">Creator Studio</a></div>
          </div>
        <% } else { %>
          <a href="/auth" class="glass-button">Entrar</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main>
    <%- body %>
  </main>

  <div id="toast-container"></div>

  <!-- Welcome Tour Modal -->
  <div id="welcome-tour" class="modal-overlay hidden" style="z-index:100;">
    <div class="glass-modal max-w-lg w-full mx-4 text-center">
      <div class="navbar-logo" style="width:80px;height:80px;border-radius:50%;margin:0 auto 1.5rem;">
        <i class="fas fa-rocket text-white text-3xl"></i>
      </div>
      <h2 class="text-2xl font-bold mb-3">Bem-vindo ao PlaysTube!</h2>
      <p style="color:var(--text-secondary);margin-bottom:1.5rem;">Vamos fazer um tour rápido para você conhecer nossa plataforma.</p>
      
      <div class="text-left mb-6" style="display:flex;flex-direction:column;gap:.75rem;">
        <div class="glass-card" style="display:flex;align-items:center;gap:.75rem;padding:.75rem;border-radius:12px;">
          <div class="btn-icon" style="background:rgba(139,92,246,0.15);border-color:transparent;color:var(--purple-light);">
            <i class="fas fa-play"></i>
          </div>
          <div>
            <h4 style="font-weight:500;">Assista Vídeos</h4>
            <p style="font-size:.875rem;color:var(--text-muted);">Descubra milhões de conteúdos</p>
          </div>
        </div>
        <div class="glass-card" style="display:flex;align-items:center;gap:.75rem;padding:.75rem;border-radius:12px;">
          <div class="btn-icon" style="background:rgba(139,92,246,0.15);border-color:transparent;color:var(--purple);">
            <i class="fas fa-video"></i>
          </div>
          <div>
            <h4 style="font-weight:500;">Crie Seu Canal</h4>
            <p style="font-size:.875rem;color:var(--text-muted);">Compartilhe seus próprios vídeos</p>
          </div>
        </div>
        <div class="glass-card" style="display:flex;align-items:center;gap:.75rem;padding:.75rem;border-radius:12px;">
          <div class="btn-icon" style="background:rgba(236,72,153,0.15);border-color:transparent;color:var(--pink);">
            <i class="fas fa-users"></i>
          </div>
          <div>
            <h4 style="font-weight:500;">Conecte-se</h4>
            <p style="font-size:.875rem;color:var(--text-muted);">Interaja com a comunidade</p>
          </div>
        </div>
      </div>
      
      <div class="flex gap-3">
        <button id="tour-skip" class="glass-button flex-1" style="justify-content:center;">Pular</button>
        <button id="tour-start" class="glass-button flex-1 primary" style="justify-content:center;">Começar Tour!</button>
      </div>
    </div>
  </div>

  <!-- Tour Tooltip -->
  <div id="tour-tooltip" class="context-menu hidden" style="position:fixed;z-index:100;max-width:320px;padding:1rem;">
    <div style="display:flex;align-items:flex-start;gap:.75rem;">
      <div id="tour-icon" class="btn-icon" style="background:rgba(139,92,246,0.15);border-color:transparent;color:var(--purple-light);flex-shrink:0;">
        <i class="fas fa-star text-sm"></i>
      </div>
      <div style="flex:1;">
        <h4 id="tour-title" style="font-weight:600;margin-bottom:.25rem;"></h4>
        <p id="tour-desc" style="font-size:.875rem;color:var(--text-secondary);"></p>
      </div>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:1rem;">
      <span id="tour-progress" style="font-size:.75rem;color:var(--text-muted);">Etapa 1 de 5</span>
      <div class="flex gap-2">
        <button id="tour-prev" class="btn-icon" style="font-size:.8rem;"><i class="fas fa-arrow-left"></i></button>
        <button id="tour-next" class="glass-button primary" style="padding:.35rem .75rem;">Próximo</button>
        <button id="tour-finish" class="glass-button" style="padding:.35rem .75rem;border-color:rgba(34,197,94,0.2);color:var(--green);display:none;">Concluir</button>
      </div>
    </div>
  </div>

  <script src="/app.js"></script>
  <script>
    const API = "http://localhost:4000/api";
    let token = localStorage.getItem("token");
    let currentUser = null;
    
    <% if (typeof user !== 'undefined' && user) { %>
      currentUser = { id: "<%= user.id %>", name: "<%= user.name %>" };
    <% } %>

    function $(sel) { return document.querySelector(sel); }
    function $$(sel) { return document.querySelectorAll(sel); }
    function show(el) { if (el) el.classList.remove("hidden"); }
    function hide(el) { if (el) el.classList.add("hidden"); }
    
    const tourSteps = [
      { title: "Página Inicial", desc: "Aqui você encontra os vídeos mais assistidos e pode buscar o que quiser!", selector: ".glass-nav", icon: "fa-home" },
      { title: "Buscar", desc: "Use a barra de busca para encontrar seus vídeos favoritos.", selector: "#search-input", icon: "fa-search" },
      { title: "Autenticação", desc: "Entre ou crie uma conta para interagir e criar conteúdo.", selector: ".glass-button", icon: "fa-sign-in-alt" },
      { title: "Seu Perfil", desc: "Gerencie suas informações, bio e pronomes.", selector: "#user-menu", icon: "fa-user" },
      { title: "Creator Studio", desc: "Crie canais, envie vídeos e acompanhe estatísticas.", selector: "a[href='/creator']", icon: "fa-video" }
    ];
    
    let currentTourStep = 0;
    
    function showWelcomeTour() {
      if (!localStorage.getItem('hasSeenWelcome') && !token) {
        show($('#welcome-tour'));
      }
    }
    
    function startTour() {
      hide($('#welcome-tour'));
      localStorage.setItem('hasSeenWelcome', 'true');
      currentTourStep = 0;
      showTourStep();
    }
    
    function showTourStep() {
      const step = tourSteps[currentTourStep];
      const tooltip = $('#tour-tooltip');
      const target = $(step.selector);
      
      if (!target) {
        nextTourStep();
        return;
      }
      
      $('#tour-title').textContent = step.title;
      $('#tour-desc').textContent = step.desc;
      $('#tour-progress').textContent = `Etapa ${currentTourStep + 1} of ${tourSteps.length}`;
      $('#tour-icon').innerHTML = `<i class="fas ${step.icon}" style="font-size:.8rem;"></i>`;
      
      const rect = target.getBoundingClientRect();
      tooltip.style.top = (rect.bottom + 10) + 'px';
      tooltip.style.left = Math.max(10, rect.left) + 'px';
      
      target.classList.add('tour-highlight');
      show(tooltip);
      
      if (currentTourStep === tourSteps.length - 1) {
        hide($('#tour-next'));
        show($('#tour-finish'));
      } else {
        show($('#tour-next'));
        hide($('#tour-finish'));
      }
    }
    
    function nextTourStep() {
      $$('.tour-highlight').forEach(el => el.classList.remove('tour-highlight'));
      hide($('#tour-tooltip'));
      
      if (currentTourStep < tourSteps.length - 1) {
        currentTourStep++;
        setTimeout(showTourStep, 300);
      } else {
        finishTour();
      }
    }
    
    function prevTourStep() {
      if (currentTourStep > 0) {
        $$('.tour-highlight').forEach(el => el.classList.remove('tour-highlight'));
        currentTourStep--;
        showTourStep();
      }
    }
    
    function finishTour() {
      $$('.tour-highlight').forEach(el => el.classList.remove('tour-highlight'));
      hide($('#tour-tooltip'));
      localStorage.setItem('tourCompleted', 'true');
      showToast('Tour concluído! Bem-vindo ao PlaysTube!');
    }
    
    $('#tour-skip')?.addEventListener('click', () => {
      hide($('#welcome-tour'));
      localStorage.setItem('hasSeenWelcome', 'true');
    });
    
    $('#tour-start')?.addEventListener('click', startTour);
    $('#tour-next')?.addEventListener('click', nextTourStep);
    $('#tour-prev')?.addEventListener('click', prevTourStep);
    $('#tour-finish')?.addEventListener('click', finishTour);
    
    setTimeout(showWelcomeTour, 2000);
    
    function showToast(message, type = 'info') {
      const container = $('#toast-container');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.innerHTML = `
        <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
        <span>${message}</span>
      `;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 4000);
    }
  </script>
</body>
</html>
